{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loop.exchange/schemas/v1alpha1/artifact-lock.schema.json",
  "title": "Loop Exchange Artifact Lock",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "artifact"],
  "properties": {
    "api_version": { "const": "loop.exchange/v1alpha1" },
    "artifact": { "$ref": "#/$defs/digest" },
    "components": { "type": "array", "items": { "$ref": "#/$defs/componentLock" } },
    "requirements": { "type": "array", "items": { "$ref": "#/$defs/requirementLock" } }
  },
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "componentLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "provider", "contract", "distribution"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "path": { "$ref": "#/$defs/path" },
        "provider": { "$ref": "#/$defs/identifier" },
        "contract": { "$ref": "#/$defs/identifier" },
        "distribution": { "enum": ["reference", "embedded", "mirrored"] },
        "revision": { "type": "string" },
        "embedded": { "type": "object", "additionalProperties": { "$ref": "#/$defs/digest" } }
      }
    },
    "path": {
      "type": "string",
      "pattern": "^(?!\\.\\.?$)(?!/)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)\\.(?:/|$))(?!\\.(?:loop|lxp)(?:/|$))(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\/$).+$"
    },
    "requirementLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "provider", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "provider": { "$ref": "#/$defs/identifier" },
        "status": { "type": "string", "minLength": 1 },
        "implementation": { "type": "string" },
        "version": { "type": "string" },
        "contract_digest": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
