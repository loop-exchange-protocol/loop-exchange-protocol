{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loop.exchange/schemas/v1alpha1/helper-message.schema.json",
  "title": "Loop Exchange Helper Message",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/response" }
  ],
  "$defs": {
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol", "id", "method"],
      "properties": {
        "protocol": { "const": "loop.exchange/helper-v1" },
        "id": { "type": "integer", "minimum": 1 },
        "method": { "type": "string", "minLength": 1 },
        "deadline": { "type": "string", "format": "date-time" },
        "params": {}
      }
    },
    "response": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol", "id"],
      "properties": {
        "protocol": { "const": "loop.exchange/helper-v1" },
        "id": { "type": "integer", "minimum": 1 },
        "result": {},
        "error": {
          "type": "object", "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string" }
          }
        }
      },
      "oneOf": [
        { "required": ["result"], "not": { "required": ["error"] } },
        { "required": ["error"], "not": { "required": ["result"] } }
      ]
    }
  }
}
